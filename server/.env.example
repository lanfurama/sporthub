# Database
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=sporthub
DATABASE_URL="postgresql://${PGUSER}:${PGPASSWORD}@${PGHOST}:${PGPORT}/${PGDATABASE}"

# Auth
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="15m"

# Server
PORT=3000
NODE_ENV=development
CLIENT_URL="http://localhost:5173"
